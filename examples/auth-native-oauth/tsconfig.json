{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "baseUrl": ".",
    "paths": {
      "xmcp": ["../../packages/xmcp/src/index.ts"],
      "xmcp/auth": ["../../packages/xmcp/src/runtime/auth.ts"],
      "@/*": ["../../packages/xmcp/src/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["xmcp-env.d.ts", "src/**/*.ts"]
}
